'use client';

import { useState, useEffect, useRef, useCallback } from 'react';

interface UserData {
  id: string;
  username: string;
  fullName: string;
  role: 'admin' | 'user';
}

/**
 * useAuth - Client-side auth hook
 * 
 * DESIGN: Uses window.location.href for ALL redirects.
 * This avoids SPA navigation race conditions where cookies
 * might not be sent with the next request.
 * 
 * The middleware protects API routes server-side.
 * This hook handles page-level auth UI.
 */
export function useAuth(requiredRole?: 'admin' | 'user') {
  const [user, setUser] = useState<UserData | null>(null);
  const [isLoading, setIsLoading] = useState(true);
  const checkedRef = useRef(false);

  const fetchUser = useCallback(async () => {
    if (checkedRef.current) return;
    checkedRef.current = true;

    try {
      setIsLoading(true);
      const res = await fetch('/api/auth/me', { credentials: 'include' });

      if (res.ok) {
        const data: UserData = await res.json();
        setUser(data);
      } else {
        // Not authenticated - force FULL page redirect to login
        // This is critical: router.replace() can fail in race conditions
        window.location.href = '/login';
        return; // Don't set isLoading(false) since we're navigating away
      }
    } catch {
      // Network error - stay in loading state, don't redirect
    } finally {
      setIsLoading(false);
    }
  }, []);

  useEffect(() => {
    fetchUser();
  }, [fetchUser]);

  const refreshAuth = useCallback(async () => {
    checkedRef.current = false;
    return fetchUser();
  }, [fetchUser]);

  const logout = useCallback(async () => {
    try {
      await fetch('/api/auth/logout', { method: 'POST', credentials: 'include' });
    } catch { /* silent */ }
    // Full page navigation to ensure everything is cleaned up
    window.location.href = '/login';
  }, []);

  const isRoleMismatch = requiredRole && user && user.role !== requiredRole;

  return {
    user,
    isAuthenticated: !!user && !isRoleMismatch,
    isLoading,
    isRoleMismatch,
    refreshAuth,
    logout,
  };
}
